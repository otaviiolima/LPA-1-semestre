programa {
  funcao inicio() {
real salarioMinimo, salarioPessoa, quantidadeSalario

escreva("Digite o valor do Salário Minimo: ", "\n")
leia(salarioMinimo)

escreva("Informe seu salário: ", "\n")
leia(salarioPessoa)

quantidadeSalario = salarioPessoa / salarioMinimo

escreva("Total de salário minimos que essa pessoa recebe: ", quantidadeSalario)



  }
}
